spring.application.name=marta
spring.datasource.url=jdbc:postgresql://YOUR_HOST/neondb?user=YOUR_USER&password=YOUR_PASSWORD&sslmode=require
spring.datasource.username=YOUR_USER
spring.datasource.password=YOUR_PASSWORD
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
server.servlet.context-path=/marta/api/v1

application.security.jwt.secret-key=YOUR_JWT_SECRET_AT_LEAST_32_CHARS

langchain4j.anthropic.chat-model.api-key=YOUR_API_KEY_HERE
langchain4j.anthropic.chat-model.model-name=claude-3-haiku-20240307
langchain4j.anthropic.chat-model.max-tokens=1000
langchain4j.anthropic.chat-model.temperature=0.25

resilience4j.ratelimiter.instances.chatLimit.limit-for-period=1
resilience4j.ratelimiter.instances.chatLimit.limit-refresh-period=3s
resilience4j.ratelimiter.instances.chatLimit.timeout-duration=0s

resilience4j.ratelimiter.instances.loginLimit.limit-for-period=5
resilience4j.ratelimiter.instances.loginLimit.limit-refresh-period=1m
resilience4j.ratelimiter.instances.loginLimit.timeout-duration=0s
